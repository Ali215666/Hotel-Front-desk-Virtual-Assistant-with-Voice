				{
					"name": "Chat - Session 1 - Book Room",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has reply field\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('reply');",
									"});",
									"",
									"pm.test(\"Reply is non-empty string\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.reply).to.be.a('string');",
									"    pm.expect(jsonData.reply.length).to.be.above(0);",
									"});",
									"",
									"pm.test(\"Response time is acceptable\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(30000);",
									"});"
								],
